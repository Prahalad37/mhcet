# Baked at `next build` — set in Vercel/host env and redeploy after any API URL change.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Canonical site URL for Open Graph / metadata (no trailing slash). Set in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — analytics load only when NODE_ENV=production (see ProductionAnalytics).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=
