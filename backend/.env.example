# Copy to .env — one line only (do not repeat DATABASE_URL in the value).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mhcet
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=
# AI_PROVIDER=mock | openai | local  (default: mock — no API key; deterministic explanations)
# AI_PROVIDER=mock
# Emergency: stop all paid LLM traffic without changing AI_PROVIDER — forces mock for POST /api/explain.
# EXPLAIN_KILL_SWITCH=true
# Mock cache/version bump (optional): MOCK_EXPLAIN_MODEL=mock-v1
# Local OpenAI-compatible API (Ollama, vLLM, etc.): LOCAL_LLM_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_MODEL=llama3.2
# LOCAL_LLM_TIMEOUT_MS=120000
# Set to false to disable Explain UI expectations without removing the route.
# EXPLAIN_AI_ENABLED=false
OPENAI_MODEL=gpt-4o-mini
# Server-only. Never commit real keys. Use a secret manager in production.
# Max OpenAI-backed explanations per user per UTC day (cache hits are free).
EXPLAIN_DAILY_LIMIT=5
# Max full mock attempts per UTC day for users with plan=free (paid = unlimited).
FREE_TESTS_PER_DAY=2
PORT=4000
# Optional overrides for `npm run reset-admin-users` (single admin; deletes all users first)
# SINGLE_ADMIN_EMAIL=superadmin@mhcet.local
# SINGLE_ADMIN_PASSWORD=
# Railway: usually omit SKIP_DB_MIGRATE so docker-entrypoint runs migrate (DATABASE_URL available). Set true only if you migrate in CI/release.
# SKIP_DB_MIGRATE=true
# Comma-separated browser origins. In NODE_ENV=production, only these origins are allowed (localhost defaults are not added).
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# Production (Vercel + Railway): set CORS_ORIGIN to your live site, e.g. https://your-app.vercel.app
# Production: https://*.vercel.app is allowed by default (opt out: CORS_ALLOW_VERCEL_APP=false).
# CORS_ALLOW_VERCEL_APP=false
# Set to true when the API sits behind a reverse proxy (X-Forwarded-* headers).
# TRUST_PROXY=false
